{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": [
    "server.ts",
    "app.ts",
    "lib/**/*.ts",
    "routes/**/*.ts",
    "controllers/**/*.ts",
    "models/**/*.ts",
    "services/**/*.ts",
    "middlewares/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "frontend",
    "scripts",
    "tests",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
