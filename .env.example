PORT=3001
CORS_ORIGINS=http://localhost:12000,http://localhost:12001
# Hops de proxy reverso confiáveis (req.ip / X-Forwarded-For). Deixe vazio em
# dev local. Em produção: 1 = um proxy (ex.: Fly/Render), 2 = Cloudflare + Fly.
TRUST_PROXY=
DATABASE_URL="sua_string_de_conexao_aqui"
JWT_SECRET="segredo_super_secreto"
# Upload de imagens via Cloudinary (free tier). Obtidas no dashboard cloudinary.com
CLOUDINARY_CLOUD_NAME="seu_cloud_name"
CLOUDINARY_API_KEY="sua_api_key"
CLOUDINARY_API_SECRET="seu_api_secret"
# Usados apenas pelo script de criação do admin (scripts/create_admin.ts)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""