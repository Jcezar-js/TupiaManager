PORT=3001
CORS_ORIGINS=http://localhost:12000,http://localhost:12001
# Hops de proxy reverso confiáveis (req.ip / X-Forwarded-For). Deixe vazio em
# dev local. Em produção: 1 = um proxy (ex.: Fly/Render), 2 = Cloudflare + Fly.
TRUST_PROXY=
DATABASE_URL="sua_string_de_conexao_aqui"
JWT_SECRET="segredo_super_secreto"
AWS_ACCESS_KEY_ID="sua_access_key"
AWS_SECRET_ACCESS_KEY="sua_secret_key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="nome-do-bucket"
CLOUDFRONT_URL="https://xxxxxx.cloudfront.net"
ADMIN_EMAIL=""
ADMIN_PASSWORD=""